# --- Facebook ---
# URLs de los grupos de Facebook a monitorear (separadas por comas)
FACEBOOK_GROUP_URLS=https://www.facebook.com/groups/GRUPO1,https://www.facebook.com/groups/GRUPO2

# Número máximo de posts a extraer por grupo en cada ejecución
MAX_POSTS_PER_GROUP=20

# --- Criterios de búsqueda ---
# Precio máximo de alquiler (en ARS)
MAX_PRECIO=300000

# Barrios preferidos en Neuquén Capital (separados por comas, dejar vacío para cualquiera)
BARRIOS_PREFERIDOS=Centro,Alta Barda,Confluencia

# ¿Acepta mascotas? (true/false)
ACEPTA_MASCOTAS=true

# Número mínimo de dormitorios
MIN_DORMITORIOS=1

# --- Google Gemini ---
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Modelo de Gemini a utilizar
GEMINI_MODEL=gemini-1.5-flash

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Chat ID del usuario o canal que recibirá las alertas
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- Base de datos ---
DB_PATH=alquileres.db

# --- Programación ---
# Intervalo de ejecución en minutos
INTERVALO_MINUTOS=60
